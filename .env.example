# Atomium AI - Environment Variables
# Copy this file to .env and fill in your values.
# Changing the model only requires editing .env and restarting the dev server.

# Gemini API key (used for compound lookups)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (reaction cache)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Fireworks AI (chat assistant and compound generation)
VITE_FIREWORKS_API_KEY=your_fireworks_api_key_here
VITE_FIREWORKS_MODEL=accounts/fireworks/models/qwen3p7-plus

# AMD Developer Cloud (chat assistant and reaction prediction)
VITE_AMD_API_ENDPOINT=https://elevating-vanish-unseen.ngrok-free.dev/generate
